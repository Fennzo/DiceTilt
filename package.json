{
  "name": "dicetilt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:frontend": "node scripts/build-frontend.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean",
    "gate": "pnpm build && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mermaid": "^11.12.3",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
